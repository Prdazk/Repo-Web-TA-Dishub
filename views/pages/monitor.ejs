<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CCTV Monitor</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
    integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
    crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Orbitron:wght@500&display=swap"
    rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
  <link href="/styles/monitor.css" rel="stylesheet" />
  <style>

.monitor-wrapper {
  display: flex;
  gap: 16px;
  padding: 16px;
  align-items: stretch;
}

.app {
  flex: 1;
  min-width: 0;
}

.detection-panel {
  width: 220px;
  flex-shrink: 0;
  background: #0f172a;
  border: 1px solid #1e293b;
  border-radius: 16px;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  justify-content: space-between; /* ← item tersebar merata */
  height: fit-content;            /* ← tidak melar ke bawah */
  position: sticky;               /* ← ikut scroll tapi tetap kelihatan */
  top: 92px;
}

.detection-panel h3 {
  margin: 0 0 8px;
  font-size: 14px;
  font-weight: 700;
  color: #f97316;
  border-bottom: 1px solid #1e293b;
  padding-bottom: 8px;
}

.count-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #1e293b;
  border-radius: 10px;
  padding: 10px 12px;
}

.count-item .icon-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: #94a3b8;
}

.count-item .value {
  font-size: 20px;
  font-weight: 800;
  color: #f1f5f9;
}

.count-item.total {
  background: #f97316;
  margin-top: 4px;
}

.count-item.total .icon-label {
  color: #fff;
  font-weight: 700;
}

.count-item.total .value {
  color: #fff;
  font-size: 22px;
}

.panel-update {
  font-size: 10px;
  color: #475569;
  text-align: center;
  margin-top: 4px;
}

.panel-status {
  font-size: 11px;
  text-align: center;
  padding: 6px;
  border-radius: 8px;
  background: #134e4a;
  color: #34d399;
}

@media (max-width: 768px) {
  .monitor-wrapper {
    flex-direction: column;
  }
  .detection-panel {
    width: 100%;
  }
}

</style>
  <link rel="icon" href="../../logo.png" />
</head>

<body>
  <div class="top-nav">
    <button class="back-btn" onclick="goBack()">← Kembali</button>
    <div class="nav-title">CCTV MONITOR</div>
  </div>

  <template id="video-template">
    <div class="card video-card">
      <div class="video-wrapper">
        <div class="overlay">Connecting…</div>
        <video autoplay muted playsinline></video>
      </div>
      <div class="controls">
        <button class="btn zoom-in">
          <i class="fa fa-search-plus" aria-hidden="true"></i> Zoom
        </button>
        <button class="btn zoom-out">
          <i class="fa fa-search-minus" aria-hidden="true"></i> Zoom
        </button>
        <button class="btn reset">Reset</button>
        <button class="btn fullscreen">
          <i class="fa fa-arrows-alt" aria-hidden="true"></i> Fullscreen
        </button>
        <strong class="label"></strong>
      </div>
    </div>
  </template>

  <div class="monitor-wrapper">

  <div class="app"></div>

  <div class="detection-panel">
    <h3>🎯 Deteksi Real-time</h3>

    <div class="count-item">
      <div class="icon-label"><span>🏍️</span> Motor</div>
      <span class="value" id="cnt-motorcycle">-</span>
    </div>

    <div class="count-item">
      <div class="icon-label"><span>🚗</span> Mobil</div>
      <span class="value" id="cnt-car">-</span>
    </div>

    <div class="count-item">
      <div class="icon-label"><span>🚌</span> Bus</div>
      <span class="value" id="cnt-bus">-</span>
    </div>

    <div class="count-item">
      <div class="icon-label"><span>🚛</span> Truk</div>
      <span class="value" id="cnt-truck">-</span>
    </div>

    <div class="count-item total">
      <div class="icon-label"><span>📊</span> Total</div>
      <span class="value" id="cnt-total">-</span>
    </div>

    <!-- Info akurasi untuk pengujian -->
    <div style="
      margin-top: 4px;
      padding: 10px 12px;
      background: #0f2744;
      border-radius: 10px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    ">
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span style="font-size:11px;color:#64748b;">🔖 ID Unik Tercatat</span>
        <span id="cnt-unique" style="font-size:13px;font-weight:700;color:#38bdf8;">-</span>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span style="font-size:11px;color:#64748b;">⚠️ Tanpa Track ID</span>
        <span id="cnt-fallback" style="font-size:13px;font-weight:700;color:#f59e0b;">-</span>
      </div>
      <div style="height:1px;background:#1e293b;margin:2px 0;"></div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span style="font-size:11px;color:#64748b;">🕐 Sejak</span>
        <span id="cnt-since" style="font-size:11px;color:#94a3b8;">-</span>
      </div>
    </div>

    <div class="panel-status" id="panel-status">⏳ Menghubungkan...</div>
    <div class="panel-update" id="panel-update"></div>
  </div>

</div>

  <div class="info">
    <div class="info-item">
      <div class="info-title">
        <i class="fa fa-map-marker" aria-hidden="true"></i> | Lokasi
      </div>
      <div class="info-value">
        <%= stream.lokasi %>
      </div>
    </div>
    <div class="info-item">
      <div class="info-title">
        <i class="fa fa-sort-amount-desc" aria-hidden="true"></i> | Stream
      </div>
      <div class="info-value" id="message-health">HLS m3u8</div>
    </div>
  </div>

  <script>
    function goBack() {
      if (history.length > 1) history.back();
      else location.href = "/";
    }

    monitor();

    async function monitor(SHOW_RAW_STREAM = false) {
      const queryString = window.location.search;
      const urlParams = new URLSearchParams(queryString);
      const raw = urlParams.get("raw");
      const app = document.querySelector(".app");
      const template = document.getElementById("video-template");

      const videoConfigs = [
        { label: "YOLO", url: "<%= hls_o %>" },
        ...(SHOW_RAW_STREAM || raw
          ? [{ label: "Raw Stream", url: "<%= hls %>" }]
          : []),
      ];

      const players = [];

      videoConfigs.forEach((config, i) => {
        const clone = template.content.cloneNode(true);

        const video = clone.querySelector("video");
        const overlay = clone.querySelector(".overlay");
        const label = clone.querySelector(".label");

        video.id = "video" + i;
        overlay.id = "overlay" + i;
        label.innerText = config.label;

        clone.querySelector(".zoom-in").onclick = () => players[i].zoomIn();
        clone.querySelector(".zoom-out").onclick = () => players[i].zoomOut();
        clone.querySelector(".reset").onclick = () => players[i].reset();
        clone.querySelector(".fullscreen").onclick = () =>
          players[i].fullscreen();

        app.appendChild(clone);

        players.push(createPlayer({ video, overlay, url: config.url }));
      });
      const rs = await fetch(`/api/server-health`);
      const js = await rs.json();
      if (js.status == "error") { document.getElementById("message-health").innerText = js.error }
    }

    function createPlayer({ video, overlay, url }) {
      let scale = 1,
        x = 0,
        y = 0,
        drag = false,
        sx = 0,
        sy = 0;
      // ✅ GANTI JADI INI
       let hls = null;
        let retryCount = 0;
        let stallTimer = null;
        let lastTime = -1;
        let isDestroyed = false;
        let isReconnecting = false;

      const apply = () =>
        (video.style.transform = `translate(${x}px,${y}px) scale(${scale})`);

      // ✅ PASTE INI DI TEMPAT YANG TADI KOSONG

      function showOverlay(msg) {
        overlay.style.display = "flex";
        overlay.innerText = msg;
      }

      function hideOverlay() {
        overlay.style.display = "none";
      }

      function startStallWatcher() {
  clearInterval(stallTimer);
  let frozenCount = 0;   // untuk readyState < 3
  let freezeCount = 0;   // untuk currentTime freeze

  stallTimer = setInterval(() => {
    if (video.paused || video.ended) return;

    // Cek readyState — kalau kurang dari 3 berarti buffer kosong
    if (video.readyState < 3) {
      frozenCount++;
      console.warn(`[HLS] Buffer rendah (readyState=${video.readyState}) count=${frozenCount}`);
      if (frozenCount >= 5) {
        console.warn("[HLS] Buffer kosong terlalu lama, reconnect...");
        frozenCount = 0;
        retryCount = 0;
        init();
      }
      return;
    }

    // Reset counter kalau normal
    frozenCount = 0;

      // Auto sync ke live edge
      if (hls && hls.liveSyncPosition) {
        const diff = hls.liveSyncPosition - video.currentTime;
        if (diff > 3) {
          console.warn("[HLS] Terlalu jauh dari live, sync...");
          try { video.currentTime = hls.liveSyncPosition; } catch(e) {}
        }
      }

      // Kalau currentTime benar-benar freeze
      if (video.currentTime === lastTime) {
        freezeCount++;
        console.warn(`[HLS] Freeze terdeteksi count=${freezeCount}`);
        if (freezeCount >= 5) {
          freezeCount = 0;
          retryCount = 0;
          init();
        }
      } else {
        freezeCount = 0;
        lastTime = video.currentTime;
      }
      }, 2000);
    }

        function init() {
      if (isDestroyed) return;
      if (isReconnecting) return;
      isReconnecting = true;
      setTimeout(() => { isReconnecting = false; }, 3000);

      clearInterval(stallTimer);
      showOverlay(retryCount > 0 ? `Reconnecting... (#${retryCount})` : "Connecting…");

      if (hls) { hls.destroy(); hls = null; }

        if (!Hls.isSupported()) {
          video.src = url;
          video.play().catch(() => {});
          hideOverlay();
          return;
        }

        hls = new Hls({
        lowLatencyMode: true,
        liveSyncDurationCount: 2,
        liveMaxLatencyDurationCount: 5,
        maxBufferLength: 8,
        maxMaxBufferLength: 16,
        maxBufferHole: 0.5,
        manifestLoadingMaxRetry: 10,
        manifestLoadingRetryDelay: 500,
        levelLoadingMaxRetry: 10,
        levelLoadingRetryDelay: 500,
        fragLoadingMaxRetry: 10,
        fragLoadingRetryDelay: 500,
        enableWorker: true,
        startFragPrefetch: true,
      });

        hls.loadSource(url);
        hls.attachMedia(video);

        hls.on(Hls.Events.MANIFEST_PARSED, () => {
          retryCount = 0;
          hideOverlay();
          video.play().catch(() => {
            video.muted = true;
            video.play().catch(() => {});
          });
          startStallWatcher();
        });

        hls.on(Hls.Events.ERROR, (_, data) => {
        console.warn("[HLS] Error:", data.type, data.details, data.fatal);

        if (!data.fatal) {
          // Buffer stall — sync ke live dulu
          if (data.details === Hls.ErrorDetails.BUFFER_STALLED_ERROR) {
            console.warn("[HLS] Buffer stall, coba sync ke live...");
            try {
              if (hls.liveSyncPosition) {
                video.currentTime = hls.liveSyncPosition;
              }
            } catch(e) {}

            // Kalau 2 detik masih stuck, reconnect
            setTimeout(() => {
              if (video.readyState < 3) {
                console.warn("[HLS] Masih stuck setelah sync, reconnect...");
                retryCount = 0;
                init();
              }
            }, 5000);
            return;
          }

          return;
        }

        // Fatal error
        retryCount++;
        const delay = Math.min(2000 * Math.pow(2, retryCount - 1), 30000);
        showOverlay(`Reconnecting... (#${retryCount})`);
        setTimeout(init, delay);
      });

      }

      video.addEventListener("stalled", () => {
        setTimeout(() => {
          try {
            if (hls && hls.liveSyncPosition && isFinite(hls.liveSyncPosition)) {
              video.currentTime = hls.liveSyncPosition;
            }
          } catch(e) {}
        }, 1000);
      });

      video.addEventListener("waiting", () => {
        setTimeout(() => {
          if (video.readyState < 3 && hls && hls.liveSyncPosition) {
            try { video.currentTime = hls.liveSyncPosition; } catch(e) {}
          }
        }, 3000);
      });

      video.addEventListener(
        "wheel",
        (e) => {
          e.preventDefault();
          scale += e.deltaY > 0 ? -0.2 : 0.2;
          scale = Math.max(1, Math.min(scale, 5));
          if (scale === 1) x = y = 0;
          apply();
        },
        { passive: false },
      );

      const p = (e) => (e.touches ? e.touches[0] : e);
      video.addEventListener("mousedown", (e) => {
        if (scale <= 1) return;
        drag = true;
        const d = p(e);
        sx = d.clientX - x;
        sy = d.clientY - y;
      });
      window.addEventListener("mousemove", (e) => {
        if (!drag) return;
        const d = p(e);
        x = d.clientX - sx;
        y = d.clientY - sy;
        apply();
      });
      window.addEventListener("mouseup", () => (drag = false));

      video.addEventListener(
        "touchstart",
        (e) => {
          if (scale <= 1) return;
          drag = true;
          const d = p(e);
          sx = d.clientX - x;
          sy = d.clientY - y;
        },
        { passive: false },
      );
      video.addEventListener(
        "touchmove",
        (e) => {
          if (!drag) return;
          e.preventDefault();
          const d = p(e);
          x = d.clientX - sx;
          y = d.clientY - sy;
          apply();
        },
        { passive: false },
      );
      video.addEventListener("touchend", () => (drag = false));

      init();

      // ✅ Auto recovery saat tab aktif kembali
      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "visible") {
            setTimeout(() => {
                if (video.readyState === 0 || video.paused) {
                    retryCount = 0;
                    init();
                }
            }, 1500);  // cek setelah 1.5 detik, reconnect hanya kalau perlu
        }
    });

      // ✅ Auto recovery saat koneksi internet kembali
      window.addEventListener("online", () => {
        console.warn("[HLS] Internet kembali, reconnect...");
        retryCount = 0;
        init();
      });

      // ✅ BARU — hanya tambah destroy() di paling bawah
      return {
        zoomIn() {
          scale = Math.min(scale + 0.2, 5);
          apply();
        },
        zoomOut() {
          scale = Math.max(scale - 0.2, 1);
          if (scale === 1) x = y = 0;
          apply();
        },
        reset() {
          scale = 1;
          x = 0;
          y = 0;
          apply();
          init();
        },
        fullscreen() {
          video.requestFullscreen?.();
        },
        destroy() {
          isDestroyed = true;
          clearInterval(stallTimer);
          hls?.destroy();
        }
      };
    }

   // ======= POLLING COUNT REAL-TIME =======
    // Ambil cctv_id dari URL, misal /monitor/cctv_1 → "cctv_1"
    const cctvIdRaw = "<%= stream.id %>";
    const cctvId = cctvIdRaw.startsWith("cctv_")
      ? cctvIdRaw
      : "cctv_" + cctvIdRaw;

    // Catat waktu mulai monitoring — ditampilkan di panel akurasi
    const monitoringSince = new Date().toLocaleTimeString("id-ID");
    document.getElementById("cnt-since").innerText = monitoringSince;

    async function fetchDetectionCounts() {
      try {
        const r = await fetch("/api/counts");
        if (!r.ok) throw new Error("HTTP " + r.status);
        const data = await r.json();

        const c = data[cctvId];
        if (!c) {
          document.getElementById("panel-status").innerText = "⚠️ Belum ada data";
          return;
        }

        // Tampilkan count per jenis kendaraan (akumulasi total dari backend)
        document.getElementById("cnt-motorcycle").innerText = c.motorcycle ?? 0;
        document.getElementById("cnt-car").innerText        = c.car       ?? 0;
        document.getElementById("cnt-bus").innerText        = c.bus       ?? 0;
        document.getElementById("cnt-truck").innerText      = c.truck     ?? 0;

        // Total semua jenis
        const total = (c.motorcycle ?? 0) + (c.car   ?? 0)
                    + (c.bus        ?? 0) + (c.truck  ?? 0);
        document.getElementById("cnt-total").innerText = total;

        // Info akurasi — unique_ids & fallback_count dari app.py
        // unique_ids   = jumlah ID unik yang sudah dihitung (anti double count)
        // fallback_count = kendaraan terdeteksi tapi YOLO tidak beri track_id
        if (c.unique_ids !== undefined) {
          document.getElementById("cnt-unique").innerText = c.unique_ids;
        }
        if (c.fallback_count !== undefined) {
          document.getElementById("cnt-fallback").innerText = c.fallback_count;
        }

        // Status Live
        const statusEl = document.getElementById("panel-status");
        statusEl.innerText    = "🟢 Live";
        statusEl.style.background = "#134e4a";
        statusEl.style.color      = "#34d399";

        document.getElementById("panel-update").innerText =
          "Update: " + new Date().toLocaleTimeString("id-ID");

      } catch (e) {
        const statusEl = document.getElementById("panel-status");
        statusEl.innerText        = "🔴 Detektor offline";
        statusEl.style.background = "#450a0a";
        statusEl.style.color      = "#f87171";
      }
    }

    // Polling tiap 3 detik
    fetchDetectionCounts();
    setInterval(fetchDetectionCounts, 3000);
    
  </script>
</body>

</html>